                        <div class="flex space-x-4 mt-4">
                            <a href="https://www.facebook.com/IAtivaidea/" target="_blank" class="text-gray-400 hover:text-white transition-colors">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="https://www.instagram.com/iativ_a/" target="_blank" class="text-gray-400 hover:text-white transition-colors">
